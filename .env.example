# ──────────────────────────────────────────────────────
# Hermes Handbook — Environment Variables
# Copy this file to .env.local and fill in real values
# ──────────────────────────────────────────────────────

# ── Clerk Authentication ──
# Get these from Clerk Dashboard → API Keys
# Or run: clerk env pull
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_xxx
CLERK_SECRET_KEY=sk_test_xxx

# ── PostHog Analytics (EU Cloud) ──
NEXT_PUBLIC_POSTHOG_KEY=phc_xxx
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com

# ── App URL ──
# Local fixed dev domain (Nginx → 127.0.0.1:3101)
NEXT_PUBLIC_APP_URL=https://handbook-dev.davidtung.net

# ── Database — Supabase Postgres ──
# IMPORTANT: Use the Supavisor pooler URL (port 6543), NOT the direct URL (port 5432)
# Format: postgresql://postgres.{project_ref}:{password}@{region}.pooler.supabase.com:6543/postgres
# Find this in Supabase Dashboard → Settings → Connection String → Transaction pooler
DATABASE_URL=postgresql://postgres.rnzrylbnfbsqdjzyewwy:YOUR_DB_PASSWORD@aws-0-ap-northeast-1.pooler.supabase.com:6543/postgres
SUPABASE_PROJECT_REF=rnzrylbnfbsqdjzyewwy

# ── Admin emails (comma-separated) ──
# Users with these emails get access to /admin/reports
ADMIN_EMAILS=thanhtung@simplamo.com

# ── Email — SMTP (Gmail) ──
# Create an App Password: Google Account → Security → 2-Step Verification → App passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=hi@davidtung.net
SMTP_PASS=your-gmail-app-password
EMAIL_FROM=hi@davidtung.net
EMAIL_REPORT_TO=thanhtung@simplamo.com

# ── Cron protection ──
# Random secret string to protect /api/cron/* endpoints
# The cron caller must send header: x-cron-secret: <this-value>
CRON_SECRET=generate-a-random-secret-here

# ── Clerk Webhook (optional — for auto-sync profiles) ──
# Create webhook in Clerk Dashboard → Webhooks → Endpoint: /api/webhook/clerk
CLERK_WEBHOOK_SECRET=whsec_xxx

# ── Backup S3/R2/B2 (optional — for daily pg_dump backup) ──
BACKUP_S3_BUCKET=
BACKUP_S3_ACCESS_KEY=
BACKUP_S3_SECRET_KEY=
BACKUP_S3_ENDPOINT=

# ── AI Chat (OpenAI-compatible / LLMGate) ──
# Ask AI docs assistant uses this provider.
# Example: LLMGate OpenAI-compatible endpoint
OPENAI_COMPAT_BASE_URL=https://llmgate.app/v1
OPENAI_COMPAT_API_KEY=
OPENAI_COMPAT_MODEL=gpt-5.4-mini

# Legacy envs (optional backwards compatibility)
LLM_GATEWAY_API_KEY=
LLM_GATEWAY_MODEL=gpt-5.4-mini